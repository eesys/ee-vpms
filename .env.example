# Service Discovery Configuration (go-zero style)
# Priority: environment variables > config.toml > defaults
#
# Direct service addresses (overrides config.toml)
OWNER_SERVICE_ADDR=http://[::1]:50051
# TENANT_SERVICE_ADDR=http://[::1]:50052
# PET_SERVICE_ADDR=http://[::1]:50053

# Logger level
LOG_LEVEL=info
